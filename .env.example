# Environment — Morfoschools Development
# Copy to .env and adjust as needed

# Ports
FRONTEND_PORT=1666
BACKEND_PORT=8080

# Backend
APP_ENV=development
LOG_LEVEL=info
SEED_DEV_DATA=true

# Database
POSTGRES_DB=morfoschools
POSTGRES_USER=morfoschools
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://morfoschools:change-me@pgbouncer:5432/morfoschools?sslmode=disable

# PgBouncer
PGBOUNCER_POOL_MODE=transaction

# Valkey
VALKEY_URL=redis://valkey:6379/0

# NATS
NATS_URL=nats://nats:4222

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# ClickHouse (optional, enable with: docker compose --profile analytics up)
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
