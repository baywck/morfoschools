# Environment — Morfoschools
# Copy to .env and replace every REQUIRED secret with a strong random value.
#
# Quick way to generate one (32+ chars):
#   openssl rand -base64 32

# Ports
FRONTEND_PORT=1666
BACKEND_PORT=8080

# Backend
APP_ENV=development        # 'development' | 'staging' | 'production'
LOG_LEVEL=info
SEED_DEV_DATA=true         # set 'false' in any non-development env

# CORS — comma-separated list of exact origin URLs (scheme + host + port).
# In development this can be left empty; backend falls back to localhost:1666.
# In staging / production this MUST be set explicitly. Browser CSRF safety
# depends on it.
#   ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
ALLOWED_ORIGINS=

# Database — REQUIRED secret. Set a 32+ char random value before first up.
# The compose stack will refuse to boot when this is empty or equal to
# 'change-me' outside development (see backend/cmd/api/main.go).
POSTGRES_DB=morfoschools
POSTGRES_USER=morfoschools
POSTGRES_PASSWORD=                                                 # REQUIRED
DATABASE_URL=postgres://morfoschools:${POSTGRES_PASSWORD}@pgbouncer:5432/morfoschools?sslmode=disable

# PgBouncer
PGBOUNCER_POOL_MODE=transaction

# Valkey
VALKEY_URL=redis://valkey:6379/0

# NATS
NATS_URL=nats://nats:4222

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# ClickHouse (optional, enable with: docker compose --profile analytics up)
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
